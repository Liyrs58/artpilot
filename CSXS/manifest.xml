<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="com.artpilot.panel"
    ExtensionBundleVersion="1.0.0"
    ExtensionBundleName="ArtPilot"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <ExtensionList>
        <Extension Id="com.artpilot.panel" Version="1.0.0" />
    </ExtensionList>

    <ExecutionEnvironment>
        <HostList>
            <!-- Illustrator CC 2024+ (v28+) through 2026+ (v30+) -->
            <Host Name="ILST" Version="[28.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="12.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>

    <DispatchInfoList>
        <Extension Id="com.artpilot.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./client/index.html</MainPath>
                    <ScriptPath>./host/index.jsx</ScriptPath>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>ArtPilot</Menu>
                    <Geometry>
                        <Size>
                            <Height>600</Height>
                            <Width>400</Width>
                        </Size>
                    </Geometry>
                </UI>
                <CEFCommandLine>
                    <Parameter>--allow-running-insecure-content</Parameter>
                    <Parameter>--disable-web-security</Parameter>
                    <Parameter>--allow-file-access-from-files</Parameter>
                </CEFCommandLine>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>

</ExtensionManifest>
